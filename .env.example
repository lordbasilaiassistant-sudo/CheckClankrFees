# Reown / WalletConnect Cloud project ID — get one free at https://cloud.reown.com
# This is a *public* identifier (it ships in the bundle) — not a secret.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: override the Base mainnet RPC. Defaults to https://mainnet.base.org
# Anything that allows eth_getLogs over a few-thousand block range works.
# Recommended: Alchemy / QuickNode / Ankr endpoint for higher rate limits.
VITE_BASE_RPC_URL=

# Optional: scan starts at this Base block — pins an absolute floor across
# every plugin. Defaults are protocol-specific (Clanker v4 factory deploy =
# 31526699, Doppler Airlock = 24000000, etc.) AND each plugin further raises
# the floor to (head - VITE_SCAN_LOOKBACK_BLOCKS), see below.
# Set this if you want to pin the start block manually.
# VITE_SCAN_FROM_BLOCK=

# Optional: look-back window. The default scan covers the most recent N
# blocks instead of all factory history — first scan finishes in ~1 min
# rather than ~15 min. Base is ~2s/block, so 4_000_000 ≈ 30 days.
# Set to 0 to disable the window and scan from each protocol's full deploy
# block (slow first scan, complete history). After the first run, cached
# scans are always fast regardless.
VITE_SCAN_LOOKBACK_BLOCKS=4000000

# Optional: block range per getLogs call. Public RPCs cap at 10k.
VITE_SCAN_CHUNK=9999

# Optional: how many chunks to fetch in parallel. The RPC aggregator fans
# parallel calls out across healthy endpoints. Default 5; raise carefully —
# more parallelism = more rate-limit hits = more aggregator fallbacks.
VITE_SCAN_CONCURRENCY=5
